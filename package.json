{
  "name": "OscGoesBrrr",
  "version": "0.0.0-dev",
  "type": "module",
  "description": "Haptics for VRChat",
  "author": {
    "name": "OscToys",
    "email": "noreply@osc.toys"
  },
  "main": "out/main/bootstrap.js",
  "scripts": {
    "preinstall": "node scripts/check-node-version.js",
    "start": "electron-vite dev",
    "build": "electron-vite build",
    "build:start": "electron .",
    "rebuild": "pnpm run build && pnpm run start",
    "typecheck": "pnpm exec tsc -p src/main/tsconfig.json --noEmit && pnpm exec tsc -p src/preload/tsconfig.json --noEmit && pnpm exec tsc -p src/frontend/tsconfig.json --noEmit"
  },
  "repository": "https://github.com/OscToys/OscGoesBrrr",
  "license": "CC BY-NC-SA 4.0",
  "engines": {
    "node": "26.5.0"
  },
  "devDependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fortawesome/fontawesome-common-types": "^7.3.0",
    "@fortawesome/fontawesome-svg-core": "^7.3.0",
    "@fortawesome/free-brands-svg-icons": "^7.3.0",
    "@fortawesome/free-solid-svg-icons": "^7.3.0",
    "@fortawesome/react-fontawesome": "^3.4.0",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "@release-it/conventional-changelog": "^11.0.1",
    "@swc/core": "^1.15.43",
    "@tanstack/query-core": "^5.101.2",
    "@tsconfig/strictest": "^2.0.8",
    "@ttsc/unplugin": "0.19.3",
    "@types/lodash": "^4.17.24",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/semver": "^7.7.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.2.0",
    "bonjour-service": "^1.4.3",
    "bootstrap": "^5.3.8",
    "chokidar": "^5.0.0",
    "classnames": "^2.5.1",
    "dns-packet": "^5.6.1",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "got": "^15.1.0",
    "immer": "^11.1.11",
    "jotai": "^2.20.1",
    "jotai-family": "^1.0.2",
    "lodash": "^4.18.1",
    "osc": "^2.4.5",
    "portfinder": "^1.0.38",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-use": "^17.6.1",
    "reflect-metadata": "^0.2.2",
    "release-it": "^20.2.1",
    "sass": "^1.101.0",
    "semver": "^7.8.5",
    "source-map-support": "^0.5.21",
    "tmp-promise": "^3.0.3",
    "tsx": "^4.23.0",
    "ttsc": "0.19.3",
    "type-fest": "^5.8.0",
    "typed-emitter": "^2.1.0",
    "typedi": "^0.10.0",
    "typescript": "^7.0.2",
    "typia": "^13.1.0",
    "vdf-parser": "^1.2.1",
    "vite": "^7.3.6",
    "ws": "^8.21.0"
  },
  "build": {
    "appId": "toys.osc.oscgoesbrrr",
    "productName": "OscGoesBrrr",
    "npmRebuild": false,
    "publish": null,
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "src/icons/ogb-logo.ico",
      "artifactName": "OscGoesBrrr-${version}.exe"
    },
    "linux": {
      "target": "AppImage",
      "icon": "src/icons/ogb-logo.png",
      "artifactName": "OscGoesBrrr.AppImage",
      "maintainer": "OscToys <noreply@osc.toys>"
    },
    "nsis": {
      "installerIcon": "src/icons/ogb-installer.ico"
    },
    "files": [
      "out/**/*"
    ]
  },
  "optionalDependencies": {
    "native-reg": "^1.1.1"
  },
  "packageManager": "pnpm@11.15.1"
}
