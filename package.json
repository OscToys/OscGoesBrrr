{
  "name": "OscGoesBrrr",
  "version": "0.0.0-dev",
  "description": "Haptics for VRChat",
  "main": "electron-main.cjs",
  "scripts": {
    "preinstall": "node -e \"const n=require('fs').readFileSync('.nvmrc','utf8').trim().replace(/^v/,'');if(process.version.slice(1).split('.')[0]!==n){console.error('Node '+process.version.slice(1)+' != .nvmrc '+n);process.exit(1)}\"",
    "start": "electron .",
    "watch": "webpack --watch --config src/main/webpack.config.js --config src/frontend/webpack.config.js",
    "watchFrontend": "cd src/frontend && webpack --watch",
    "watchMain": "cd src/main && webpack --watch",
    "build": "webpack --config src/main/webpack.config.js --config src/frontend/webpack.config.js",
    "rebuild": "pnpm run build && pnpm run start",
    "typecheck": "pnpm exec tsc -p src/main/tsconfig.json --noEmit && pnpm exec tsc -p src/frontend/tsconfig.json --noEmit"
  },
  "repository": "https://github.com/OscToys/OscGoesBrrr",
  "license": "CC BY-NC-SA 4.0",
  "engines": {
    "node": "24"
  },
  "devDependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fortawesome/fontawesome-common-types": "^7.2.0",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.2.0",
    "@homebridge/ciao": "^1.3.5",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@tanstack/query-core": "^5.90.20",
    "@tsconfig/strictest": "^2.0.8",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/semver": "^7.7.1",
    "@types/ws": "^8.18.1",
    "bonjour-service": "^1.3.0",
    "chokidar": "^5.0.0",
    "classnames": "^2.5.1",
    "css-loader": "^7.1.4",
    "electron": "^40.7.0",
    "electron-builder": "^26.8.1",
    "got": "^14.6.6",
    "immer": "^11.1.4",
    "jotai": "^2.18.0",
    "jotai-family": "^1.0.1",
    "lodash": "^4.17.23",
    "osc": "^2.4.5",
    "oscquery": "^1.1.1",
    "portfinder": "^1.0.38",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-use": "^17.6.0",
    "reflect-metadata": "^0.2.2",
    "sass": "^1.97.3",
    "sass-loader": "^16.0.7",
    "semver": "^7.7.4",
    "source-map-support": "^0.5.21",
    "style-loader": "^4.0.0",
    "tmp-promise": "^3.0.3",
    "ts-loader": "^9.5.4",
    "tsx": "^4.21.0",
    "type-fest": "^5.4.4",
    "typed-emitter": "^2.1.0",
    "typedi": "^0.10.0",
    "typescript": "^5.9.3",
    "typia": "^11.0.3",
    "vdf-parser": "^1.2.1",
    "webpack": "^5.105.4",
    "webpack-cli": "^6.0.1",
    "ws": "^8.19.0"
  },
  "build": {
    "appId": "toys.osc.oscgoesbrrr",
    "productName": "OscGoesBrrr",
    "npmRebuild": false,
    "publish": null,
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "src/icons/ogb-logo.ico",
      "artifactName": "OscGoesBrrr-${version}.exe"
    },
    "linux": {
      "target": "AppImage",
      "icon": "src/icons/ogb-logo.png",
      "artifactName": "OscGoesBrrr.AppImage"
    },
    "nsis": {
      "installerIcon": "src/icons/ogb-installer.ico"
    },
    "files": [
      "app/**/*",
      "electron-main.cjs"
    ]
  },
  "optionalDependencies": {
    "native-reg": "^1.1.1"
  },
  "packageManager": "pnpm@10.30.3"
}
