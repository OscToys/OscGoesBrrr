{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "schedule": [
    "before 6am on monday"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)\\.npmrc$/"
      ],
      "matchStrings": [
        "^use-node-version=(?<currentValue>\\S+)$"
      ],
      "depNameTemplate": "node",
      "datasourceTemplate": "node-version",
      "versioningTemplate": "node"
    }
  ],
  "packageRules": [
    {
      "matchManagers": [
        "npm",
        "nvm",
        "custom.regex"
      ],
      "matchPackageNames": [
        "node",
        "@types/node"
      ],
      "groupName": "node.js"
    }
  ]
}
